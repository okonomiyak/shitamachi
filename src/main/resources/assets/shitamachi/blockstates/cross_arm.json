{
  "multipart": [
    { "apply": { "model": "shitamachi:block/cross_arm_post" } },
    { "when": { "north":  "true" }, "apply": { "model": "shitamachi:block/cross_arm",          "uvlock": true } },
    { "when": { "south":  "true" }, "apply": { "model": "shitamachi:block/cross_arm",          "uvlock": true, "y": 180 } },
    { "when": { "east":   "true" }, "apply": { "model": "shitamachi:block/cross_arm",          "uvlock": true, "y": 90  } },
    { "when": { "west":   "true" }, "apply": { "model": "shitamachi:block/cross_arm",          "uvlock": true, "y": 270 } },
    { "when": { "arm_ne": "true" }, "apply": { "model": "shitamachi:block/cross_arm_diagonal", "uvlock": true } },
    { "when": { "arm_se": "true" }, "apply": { "model": "shitamachi:block/cross_arm_diagonal", "uvlock": true, "y": 90  } },
    { "when": { "arm_sw": "true" }, "apply": { "model": "shitamachi:block/cross_arm_diagonal", "uvlock": true, "y": 180 } },
    { "when": { "arm_nw": "true" }, "apply": { "model": "shitamachi:block/cross_arm_diagonal", "uvlock": true, "y": 270 } },
    { "when": { "up":     "true" }, "apply": { "model": "shitamachi:block/cross_arm",          "uvlock": true, "x": 270 } },
    { "when": { "down":   "true" }, "apply": { "model": "shitamachi:block/cross_arm",          "uvlock": true, "x": 90  } },
    { "when": { "insulator_north": "true" }, "apply": { "model": "shitamachi:block/insulator" } },
    { "when": { "insulator_south": "true" }, "apply": { "model": "shitamachi:block/insulator", "y": 180 } },
    { "when": { "insulator_east":  "true" }, "apply": { "model": "shitamachi:block/insulator", "y": 90  } },
    { "when": { "insulator_west":  "true" }, "apply": { "model": "shitamachi:block/insulator", "y": 270 } }
  ]
}
